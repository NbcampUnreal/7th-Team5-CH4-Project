# 이미지 / 미디어 파일
*.png  lfs
*.ico  lfs
*.icns lfs
*.bk2  lfs
*.jpg  lfs
*.jpeg lfs
*.tga  lfs
*.psd  lfs

# 3D / source assets
*.fbx   lfs
*.blend lfs
*.hdr   lfs
*.exr   lfs

# Steam Audio
*.phononscene lfs
*.probebox    lfs
*.probebatch  lfs
*.bakedsources lfs